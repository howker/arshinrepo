APP_NAME=arshin-excel-verifier
APP_ENV=dev
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_BASE_URL=http://localhost

API_PREFIX=/api
SECRET_KEY=change-me-super-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=60
BASIC_AUTH_ENABLED=true

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=arshin_mvp
POSTGRES_USER=arshin
POSTGRES_PASSWORD=arshin

DATABASE_URL=postgresql+psycopg://arshin:arshin@postgres:5432/arshin_mvp
ALEMBIC_DATABASE_URL=postgresql+psycopg://arshin:arshin@postgres:5432/arshin_mvp

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=miniosecret
MINIO_SECURE=false
MINIO_BUCKET_SOURCE=source-files
MINIO_BUCKET_RESULT=result-files

ARSHIN_BASE_URL=https://fgis.gost.ru/fundmetrology
ARSHIN_SEARCH_ENDPOINT=/api/v1/placeholder/search
ARSHIN_TIMEOUT_SECONDS=20
ARSHIN_MAX_RETRIES=4
ARSHIN_BACKOFF_SECONDS=2

LOG_LEVEL=INFO
LOG_JSON=true
