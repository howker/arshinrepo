# =============================================================================
# Arshin Excel Checker — переменные окружения (MVP по ТЗ v3)
# Скопируй в .env и заполни секретные значения.
# =============================================================================

# --- App ---
APP_NAME=arshin-excel-verifier
APP_ENV=prod
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000
APP_BASE_URL=http://localhost
API_PREFIX=/api

# --- Security ---
SECRET_KEY=CHANGE_ME_TO_RANDOM_64_CHARS
ACCESS_TOKEN_EXPIRE_MINUTES=1440
BASIC_AUTH_ENABLED=false

# --- Postgres ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=arshin
POSTGRES_USER=arshin
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD

DATABASE_URL=postgresql+psycopg://arshin:CHANGE_ME_POSTGRES_PASSWORD@postgres:5432/arshin
ALEMBIC_DATABASE_URL=postgresql+psycopg://arshin:CHANGE_ME_POSTGRES_PASSWORD@postgres:5432/arshin

# --- Redis ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# --- Storage (локальный диск, НЕ MinIO — ТЗ §2.3, §5) ---
STORAGE_ROOT=/app/storage
MAX_UPLOAD_MB=25

# --- Arshin API (ТЗ §1, §9, §17) ---
ARSHIN_API_MODE=xcdb                              # xcdb | eapi
ARSHIN_XCDB_URL=https://fgis.gost.ru/fundmetrology/cm/xcdb/vri/select
ARSHIN_EAPI_URL=https://fgis.gost.ru/fundmetrology/eapi/vri
ARSHIN_CARD_URL=https://fgis.gost.ru/fundmetrology/cm/results
ARSHIN_ROWS=100
ARSHIN_REQUEST_DELAY_MS=1000                      # пауза между запросами (500..5000)
ARSHIN_TIMEOUT_CONNECT=5
ARSHIN_TIMEOUT_READ=20
ARSHIN_MAX_RETRIES=4
ARSHIN_BACKOFF_SECONDS=2
ARSHIN_YEAR_SWEEP=false

# --- Templates / Seed ---
DEFAULT_TEMPLATE_CODE=pril_1_main
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# --- Logging ---
LOG_LEVEL=INFO
LOG_JSON=true
